{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://18.232.33.127:8000/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "http://18.232.33.127:8000/media/:path*"
    },
    {
      "source": "/((?!assets/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
