{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.findgarageandyardsale.com/api/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://api.findgarageandyardsale.com/media/:path*"
    },
    {
      "source": "/((?!assets/)(?!.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
